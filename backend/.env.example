# Copy to .env and adjust to your local setup.

# PostgreSQL connection string (Prisma). Adjust user/password/db/host as needed.
DATABASE_URL="postgresql://postgres:password@localhost:5432/task_tracker?schema=public"

# Port the NestJS API listens on.
PORT=3000

# Auth — long random string; the backend will not boot without it.
# Generate one with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret
# Optional token lifetime (ms-style duration). Defaults to 7d.
JWT_EXPIRES_IN=7d

# CORS — comma-separated allowed frontend origins. Optional; sensible
# defaults (localhost + deployed SPA) apply when unset.
CORS_ORIGIN=http://localhost:5173
